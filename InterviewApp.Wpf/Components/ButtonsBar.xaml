<UserControl x:Class="InterviewApp.Wpf.ButtonsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:InterviewApp.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
            <Button Content="Main" Width="100" Height="30" Click="GoToMainPage"/>
            <Button Content="Categories" Width="100" Height="30" Click="GoToCategoriesPage"/>
            <Button Content="Questions" Width="100" Height="30" Click="GoToQuestionsPage"/>
            <Button Content="Interviews" Width="100" Height="30" Click="GoToInterviewsPage"/>
            <Button Content="Settings" Width="100" Height="30" Click="GoToSettingsPage"/>
        </StackPanel>
    </Grid>
</UserControl>
